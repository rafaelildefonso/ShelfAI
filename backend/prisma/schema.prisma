generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        String    @default("USER") // "ADMIN" | "USER"
  // Campos adicionais de informações do usuário
  phone       String?
  avatar      String?
  company     String?
  department  String?
  position    String?
  location    String?
  timezone    String    @default("America/Sao_Paulo")
  language    String    @default("pt-BR")
  // Configurações e preferências
  preferences Json?     // Para armazenar configurações personalizadas do usuário
  settings    Json?     // Para configurações específicas da aplicação
  // Status e controle
  isActive    Boolean   @default(true)
  lastLogin   DateTime?
  loginCount  Int       @default(0)
  // Auditoria
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  // Relacionamentos
  products    Product[]
  categories  Category[]
  importTemplates ImportTemplate[]
  createdProducts Product[] @relation("CreatedByUser")
  updatedProducts Product[] @relation("UpdatedByUser")
  notifications Notification[]
  activities  Activity[]

  @@index([email])
  @@index([phone])
  @@index([company])
  @@index([isActive])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  products    Product[]
  userId      String?   // Alterado para permitir nulo
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, userId])
}

model Product {
  id                      String    @id @default(cuid())
  name                    String
  description             String?
  price                   Float?
  originalPrice           Float?
  costPrice               Float?
  categoryId              String?
  category                Category? @relation(fields: [categoryId], references: [id])
  subcategory             String?
  brand                   String?
  sku                     String?
  status                  String    @default("incomplete")
  weight                  Float?
  length                  Float?
  width                   Float?
  height                  Float?
  tags                    String[]
  featured                Boolean   @default(false)
  active                  Boolean   @default(true)
  image                   String?
  images                  String[]
  model                   String?
  color                   String?
  size                    String?
  material                String?
  stockLocation           String?
  origin                  String?
  createdById             String?
  createdBy               User?     @relation("CreatedByUser", fields: [createdById], references: [id])
  lastEditedById          String?
  lastEditedBy            User?     @relation("UpdatedByUser", fields: [lastEditedById], references: [id])
  marketplaceIntegrations Json?
  templateData            Json?
  internalNotes           String?
  rating                  Float?    @default(0)
  reviewCount             Int       @default(0)
  views                   Int       @default(0)
  sales                   Int       @default(0)
  userId                  String?
  user                    User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([sku])
  @@index([categoryId])
  @@index([status])
  @@index([userId])
  @@index([createdById])
  @@index([lastEditedById])
}

model ImportTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  fileType    String   // 'csv' | 'xlsx'
  delimiter   String?  // Para CSV: ',' | ';' | '\t'
  mapping     Json     // Mapeamento de colunas: { "productField": "csvColumnName" }
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, userId])
  @@index([userId])
  @@index([isDefault])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String   @default("info") // "info" | "success" | "warning" | "error"
  read        Boolean  @default(false)
  link        String?  // Link opcional para ação relacionada
  metadata    Json?    // Dados adicionais da notificação
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "import" | "export" | "product" | "category" | "user" | "system"
  action      String   // "create" | "update" | "delete" | "import" | "export"
  title       String
  description String
  status      String   @default("info") // "success" | "warning" | "error" | "info"
  entityType  String?  // Tipo da entidade afetada (Product, Category, etc)
  entityId    String?  // ID da entidade afetada
  metadata    Json?    // Dados adicionais da atividade
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
}