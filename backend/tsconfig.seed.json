{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "outDir": "./dist-seed",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["prisma/seed.ts"],
  "exclude": ["node_modules"]
}